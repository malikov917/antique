{
  "name": "antique",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "check": "./scripts/check.sh",
    "ensure:local": "./scripts/ensure-local.sh",
    "ensure:happy-path": "./scripts/ensure-mobile-happy-path.sh",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @antique/types exec tsc -b tsconfig.json --force && pnpm --filter @antique/mobile typecheck && tsc -b",
    "test": "pnpm -r test",
    "dev:mobile": "pnpm --filter @antique/mobile dev",
    "dev:api": "pnpm --filter @antique/api dev",
    "build": "pnpm --filter @antique/api build"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "eslint": "^9.20.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
